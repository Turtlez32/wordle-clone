{
  "name": "neon-wordle",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "bunx concurrently -k \"bun run dev:server\" \"bun run dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "bun run server.ts",
    "build": "tsc -b && vite build",
    "preview": "bun run server.ts",
    "start": "bun run server.ts"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "redis": "^5.8.2"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  }
}
